    },
    {
      "parameters": {
        "sendTo": "={{ $('Webhook').item.json.body.email }}",
        "subject": "Hier is je gratis CLAUDE template!",
        "emailType": "html",
        "message": "<div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 520px; margin: 0 auto; padding: 32px 20px; color: #1a1a1a;\">\n<p style=\"font-size: 18px; margin-bottom: 16px;\">Hey {{ $('Webhook').item.json.body.name || 'daar' }}!</p>\n\n<p style=\"font-size: 16px; line-height: 1.6; margin-bottom: 16px;\">Nice dat je hem hebt aangevraagd. Dit is je persoonlijke CLAUDE.md template voor Claude Code.</p>\n\n<p style=\"font-size: 16px; line-height: 1.6; margin-bottom: 20px;\"><a href=\"https://drive.google.com/file/d/1b7jW2HnFzXn8xYCLhSFPK8Adn16GMAep/view?usp=sharing\" style=\"display: inline-block; padding: 14px 28px; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: #ffffff; text-decoration: none; border-radius: 10px; font-weight: 600; font-size: 16px;\">Download je CLAUDE.md template</a></p>\n\n<p style=\"font-size: 16px; line-height: 1.6; margin-bottom: 16px;\"><strong>Hoe je hem gebruikt:</strong></p>\n<ol style=\"font-size: 16px; line-height: 1.8; margin-bottom: 24px;\">\n<li>Sla het bestand op als <code>CLAUDE.md</code> in je projectmap</li>\n<li>Open Claude Code in die map</li>\n<li>Type iets \u2014 Claude start automatisch het interview</li>\n<li>Beantwoord de vragen en je hebt een persoonlijke AI-assistent</li>\n</ol>\n\n<p style=\"font-size: 16px; line-height: 1.6; margin-bottom: 24px;\">Vragen? Stuur me een DM op Instagram \u2014 ik help je graag.</p>\n\n<p style=\"font-size: 16px; margin-bottom: 8px;\">Groeten,<br><strong>Davy</strong></p>\n<a href=\"https://instagram.com/davyv.ai\" style=\"color: #6366f1; text-decoration: none; font-size: 14px;\">@davyv.ai op Instagram</a>\n</div>",
        "options": {}
      },
